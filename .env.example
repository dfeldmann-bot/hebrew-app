# Passphrase gate — REQUIRED. Any string; you type it once in the browser.
# If unset, the app rejects every request (401).
APP_PASSPHRASE=

# Free model providers — SERVER-SIDE ONLY, never exposed to the browser.
# At least one is required. The chain tries them in order; missing ones are skipped.
# Primary — Google AI Studio: https://ai.google.dev
GOOGLE_AI_API_KEY=
# Fallback 1 — Groq: https://console.groq.com
GROQ_API_KEY=
# Fallback 2 — OpenRouter: https://openrouter.ai
OPENROUTER_API_KEY=

# Optional model overrides (defaults shown). Confirm current free IDs in each provider's docs.
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
